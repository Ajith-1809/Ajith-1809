# This patch adds SUSFS_MAGIC (0xFAFAFAFA) routing to KSUN's
# ksu_handle_sys_reboot so that the susfs userspace binary's
# reboot(0xDEADBEEF, 0xFAFAFAFA, cmd, data) calls reach our
# susfs_handle_sys_reboot() dispatcher.
#
# Applied via sed in the CI workflow after KSUN integration.

--- a/kernel/supercall/supercall.c
+++ b/kernel/supercall/supercall.c
@@ -225,6 +225,14 @@ int ksu_handle_sys_reboot(int magic1, int
 			return 0;
 	}

+#ifdef CONFIG_KSU_SUSFS
+	/* SUSFS command dispatch (magic2 = 0xFAFAFAFA) */
+	if (magic2 == SUSFS_MAGIC) {
+		extern int susfs_handle_sys_reboot(unsigned int cmd, void __user *arg);
+		return susfs_handle_sys_reboot(cmd, *arg);
+	}
+#endif
+
 	return 0;
 }

