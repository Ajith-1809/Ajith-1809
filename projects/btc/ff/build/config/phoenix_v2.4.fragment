# SUSFS features for phoenix kernel (tillua467 source, v2.4 tag)
# Appended to vendor/phoenix_defconfig before olddefconfig
# This enables all SUSFS features including GKI backport features

# KernelSU core (always needed)
CONFIG_KSU=y
CONFIG_KSU_SUSFS=y

# KernelSU hooks (kprobes-based for non-GKI kernels 4.14)
CONFIG_KSU_KPROBES_HOOK=y
CONFIG_KSU_SUSFS_HAS_MAGIC_MOUNT=y

# SUSFS core features
CONFIG_KSU_SUSFS_SUS_PATH=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_SUS_KSU_DEFAULT_MOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_SUS_BIND_MOUNT=y
CONFIG_KSU_SUSFS_SUS_KSTAT=y
CONFIG_KSU_SUSFS_SUS_OVERLAYFS=y
CONFIG_KSU_SUSFS_TRY_UMOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_TRY_UMOUNT_FOR_BIND_MOUNT=y
CONFIG_KSU_SUSFS_SPOOF_UNAME=y
CONFIG_KSU_SUSFS_ENABLE_LOG=y
CONFIG_KSU_SUSFS_HIDE_KSU_SUSFS_SYMBOLS=y
CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG=y
CONFIG_KSU_SUSFS_OPEN_REDIRECT=y

# GKI SUSFS backport features
CONFIG_KSU_SUSFS_SUS_MAP=y
CONFIG_KSU_SUSFS_SUS_MEMFD=y
CONFIG_KSU_SUSFS_SUS_PROC_FD_LINK=y

# Additional hardening
CONFIG_KSU_SUSFS_SUS_MOUNT_REMOUNT=y
CONFIG_KSU_SUSFS_SUS_BRIDGE_FILTER=y
CONFIG_KSU_SUSFS_SUS_KSTAT_FULL_SPOOF=y
CONFIG_KSU_SUSFS_SUS_KSTAT_STATICALLY=y
